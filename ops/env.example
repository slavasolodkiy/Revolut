# NovaPay Reference Platform — Environment Variables
# Copy this file to .env and fill in the values

# =========================================
# DATABASE
# =========================================
DATABASE_URL=postgresql://novapay:password@localhost:5432/novapay_dev
PGHOST=localhost
PGPORT=5432
PGUSER=novapay
PGPASSWORD=password
PGDATABASE=novapay_dev

# =========================================
# SERVER
# =========================================
NODE_ENV=development
PORT=8080
SESSION_SECRET=change_this_to_a_random_secret_in_production
LOG_LEVEL=info

# =========================================
# FRONTEND
# =========================================
VITE_PORT=3000
BASE_PATH=/

# =========================================
# KYC VENDOR (Onfido)
# =========================================
ONFIDO_API_KEY=
ONFIDO_WEBHOOK_SECRET=
# Alternative: Sumsub
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=

# =========================================
# PAYMENTS RAIL (Modulr / Stripe)
# =========================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
MODULR_API_KEY=
MODULR_HMAC_SECRET=

# =========================================
# FX RATES
# =========================================
EXCHANGE_RATE_API_KEY=
# https://www.exchangerate-api.com

# =========================================
# COMMUNICATIONS
# =========================================
# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SendGrid (Email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@novapay.example.com

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# =========================================
# FRAUD / AML
# =========================================
COMPLYADVANTAGE_API_KEY=
SIFT_API_KEY=

# =========================================
# ANALYTICS
# =========================================
MIXPANEL_TOKEN=

# =========================================
# FEATURE FLAGS (optional)
# =========================================
FEATURE_CRYPTO=false
FEATURE_STOCKS=false
FEATURE_LENDING=false
FEATURE_INSURANCE=false
